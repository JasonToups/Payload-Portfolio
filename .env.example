# PostgreSQL connection (Vercel Postgres adapter — Neon in production, Docker locally)
# Local Docker: postgresql://postgres:password@localhost:5433/now-hiring
# Production (Neon): copy from Vercel dashboard → Settings → Environment Variables
POSTGRES_URL=postgresql://127.0.0.1:5433/your-database-name

# Used to encrypt JWT tokens
PAYLOAD_SECRET=YOUR_SECRET_HERE

# Used to configure CORS, format links and more. No trailing slash
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Secret used to authenticate cron jobs
CRON_SECRET=YOUR_CRON_SECRET_HERE

# Used to validate preview requests
PREVIEW_SECRET=YOUR_SECRET_HERE

# Resend used for email
RESEND_API_KEY=your_resend_api_key
RESEND_FROM_NAME=Your Name or Brand
RESEND_FROM_ADDRESS=youraddress@email.com
# Resend webhook signing secret (Resend Dashboard → Webhooks → signing secret)
RESEND_WEBHOOK_SECRET=your_resend_webhook_signing_secret
UNSUBSCRIBE_SECRET=YOUR_UNSUBSCRIBE_SECRET_HERE

# Vercel Blob Storage (for media uploads)
BLOB_READ_WRITE_TOKEN=your_blob_token

# LinkedIn OAuth (for admin panel direct posting)
# Create an app at https://www.linkedin.com/developers/apps
# Add products: "Share on LinkedIn" + "Sign In with LinkedIn using OpenID Connect"
LINKEDIN_CLIENT_ID=your_linkedin_client_id
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret
LINKEDIN_REDIRECT_URI=http://localhost:3000/api/linkedin/callback
